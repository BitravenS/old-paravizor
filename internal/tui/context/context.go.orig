package context

import (
	"fmt"

	"github.com/bitravens/paravizor/v1/internal/config"
	"github.com/bitravens/paravizor/v1/internal/engine"
	"github.com/bitravens/paravizor/v1/internal/project"
	"github.com/bitravens/paravizor/v1/internal/theme"
	"github.com/bitravens/paravizor/v1/internal/tui/constants"
)

// ProgramContext holds the application's global state needed by TUI components.
type ProgramContext struct {
	Config   *config.Config
	Project    *project.ProjectConfig // Nil if running outside of a project
	ProjectDir string
	Theme    *theme.Theme
	Pipeline *engine.PipelineConfig
	Window   constants.Dimensions
	Version    string
}

// NewProgramContext initializes the context by parsing configuration and loading the theme.
// location is either empty (running globally) or points to a project directory.
func NewProgramContext(location string) (*ProgramContext, error) {
	var proj *project.ProjectConfig

	// 1. Load config (automatically handles global vs project overrides safely)
	cfg := config.LoadConfig(location)

	// 2. Load project config if location is provided
	if location != "" {
		pCfg, pErr := project.LoadProject(location)
		if pErr != nil {
			return nil, pErr
		}
		proj = &pCfg
	}

	// 3. Load Theme
	tCfg, tErr := theme.LoadExternalTheme(cfg.Theme)
	if tErr != nil {
		// Just log and continue, tCfg will be nil and LoadTheme will use defaults
		_ = tErr
	}
	t := theme.LoadTheme(tCfg)

	// 4. Load Pipeline
	pipelineName := cfg.DefaultPipeline
	if proj != nil && proj.Pipeline != "" {
		pipelineName = proj.Pipeline
	}
	pipeline, pErr := engine.LoadExternalPipeline(pipelineName)
	if pErr != nil {
		if pipeline == nil {
			return nil, fmt.Errorf("failed to load pipeline and fallback also failed: %w", pErr)
		}
		// We have a fallback pipeline, but we should log that an error occurred.
		// log.Warn already ran in LoadExternalPipeline, so we can just proceed.
	}

	return &ProgramContext{
		Config:   &cfg,
		Project:  proj,
		Theme:    t,
		Pipeline: pipeline,
	}, nil
}
